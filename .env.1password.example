# Copy this file to .env.1password and replace VAULT and ITEM with your
# 1Password vault and item names. Secret values are resolved only by `op run`.

# Secrets
OPENAI_API_KEY=op://VAULT/ITEM/OPENAI_API_KEY
SUPABASE_SERVICE_ROLE_KEY=op://VAULT/ITEM/SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_URL=op://VAULT/ITEM/SUPABASE_DB_URL
DEMO_RESET_TOKEN=op://VAULT/ITEM/DEMO_RESET_TOKEN
DEMO_ACCESS_PASSWORD=op://VAULT/ITEM/DEMO_ACCESS_PASSWORD

# Non-secret configuration (replace values locally as services are provisioned)
OPENAI_MODEL=SET_HACKATHON_MODEL_ID
NEXT_PUBLIC_SUPABASE_URL=https://SET_PROJECT_REF.supabase.co
DEMO_PROFILE_ID=00000000-0000-4000-8000-000000000001
DEMO_SAFE_MODE=fallback
