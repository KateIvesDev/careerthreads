{
  "name": "careerthread",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.14.x"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "next dev",
    "dev:secure": "op run --env-file=.env.1password -- npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:secure": "op run --env-file=.env.1password -- npm run test:e2e",
    "test:e2e:fixture:secure": "op run --env-file=.env.1password -- env PLAYWRIGHT_ISOLATED=1 DEMO_SAFE_MODE=fixture npm run test:e2e -- demo-flow",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:secure": "op run --env-file=.env.1password -- npm run db:migrate",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:seed:secure": "op run --env-file=.env.1password -- npm run db:seed",
    "db:verify": "tsx scripts/db-verify.ts",
    "db:verify:secure": "op run --env-file=.env.1password -- npm run db:verify",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "demo:reset:secure": "op run --env-file=.env.1password -- npm run demo:reset --",
    "secrets:check": "op run --env-file=.env.1password -- tsx scripts/secrets-check.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:secure": "op run --env-file=.env.1password -- npm run smoke --"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "next": "16.2.10",
    "openai": "^6.48.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
